---
import { Image } from "astro:assets";
import "../styles/global.css";
import logo from "../assets/logo.png";
import { documento, empresa, legales, seccionesNav } from "../data/site";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const enLegales = currentPath.startsWith("/anexo") || currentPath === "/terminos-y-condiciones";

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og.png", Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_PE" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="text-tinta bg-white font-sans antialiased">
    <header class="bg-carbon/95 sticky top-0 z-50 border-b border-white/10 backdrop-blur">
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-5 py-3">
        <a href="/" class="flex items-center gap-3">
          <Image src={logo} alt="FEMAXX" height={72} class="h-12 w-auto sm:h-14" />
          <span class="sr-only">FEMAXX — Inicio</span>
        </a>

        <nav class="hidden items-center gap-1 md:flex">
          {
            seccionesNav.map((s) => (
              <a
                href={s.href}
                class="rounded-full px-4 py-1.5 text-sm font-medium text-gray-300 transition-colors hover:bg-white/10 hover:text-white"
              >
                {s.label}
              </a>
            ))
          }
          <div class="group relative" data-dropdown>
            <button
              type="button"
              aria-expanded="false"
              aria-haspopup="true"
              class:list={[
                "flex items-center gap-1.5 rounded-full px-4 py-1.5 text-sm font-medium transition-colors",
                enLegales ? "bg-verde text-white" : "text-gray-300 hover:bg-white/10 hover:text-white",
              ]}
            >
              Legal
              <svg
                class="h-3.5 w-3.5 transition-transform group-hover:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"></path>
              </svg>
            </button>
            <div
              class="invisible absolute top-full right-0 w-80 pt-2 opacity-0 transition-all group-focus-within:visible group-focus-within:opacity-100 group-hover:visible group-hover:opacity-100"
            >
              <ul class="border-borde overflow-hidden rounded-xl border bg-white shadow-xl">
                {
                  legales.map((a) => (
                    <li>
                      <a
                        href={a.href}
                        class:list={[
                          "border-borde/60 hover:bg-crema block border-b px-4 py-3 text-sm transition-colors last:border-b-0",
                          currentPath === a.href ? "text-verde-oscuro font-semibold" : "text-tinta",
                        ]}
                      >
                        {a.label}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </nav>

        <details class="relative md:hidden">
          <summary
            class="flex cursor-pointer list-none items-center rounded-lg p-2 text-gray-200 hover:bg-white/10 [&::-webkit-details-marker]:hidden"
          >
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
            </svg>
            <span class="sr-only">Abrir menú</span>
          </summary>
          <div class="absolute top-full right-0 z-50 mt-2 w-72">
            <ul class="border-borde overflow-hidden rounded-xl border bg-white shadow-xl">
              {
                seccionesNav.map((s) => (
                  <li>
                    <a
                      href={s.href}
                      class="border-borde/60 text-carbon hover:bg-crema block border-b px-4 py-3 text-sm font-semibold"
                    >
                      {s.label}
                    </a>
                  </li>
                ))
              }
              {
                legales.map((a) => (
                  <li>
                    <a
                      href={a.href}
                      class="border-borde/60 text-tinta hover:bg-crema block border-b px-4 py-3 text-sm last:border-b-0"
                    >
                      {a.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </details>
      </div>
    </header>

    <slot />

    <a
      href="https://wa.me/51922030906?text=Hola%2C%20quiero%20información%20sobre%20FeMax"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
      title="Contactar por WhatsApp"
      class="fixed right-5 bottom-5 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-lg transition-transform hover:scale-110 hover:bg-[#20bd5a] focus-visible:ring-4 focus-visible:ring-[#25D366]/40 focus-visible:outline-none sm:right-6 sm:bottom-6 sm:h-16 sm:w-16"
    >
      <svg
        aria-hidden="true"
        class="h-8 w-8 sm:h-9 sm:w-9"
        viewBox="0 0 16 16"
        fill="currentColor"
      >
        <path
          d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"
        ></path>
      </svg>
    </a>

    <footer class="bg-carbon text-gray-400">
      <div class="mx-auto grid max-w-5xl gap-10 px-5 py-12 md:grid-cols-3">
        <div>
          <Image src={logo} alt="FEMAXX" height={80} class="mb-4 h-10 w-auto" />
          <p class="text-sm leading-relaxed">
            Plataforma SaaS de gestión empresarial y facturación electrónica conforme a la normativa de la
            SUNAT.
          </p>
        </div>
        <div>
          <h3 class="text-naranja mb-3 text-xs font-bold tracking-wider uppercase">Legal</h3>
          <ul class="space-y-2 text-sm">
            {
              legales.map((a) => (
                <li>
                  <a href={a.href} class="transition-colors hover:text-white">
                    {a.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <h3 class="text-verde mb-3 text-xs font-bold tracking-wider uppercase">Contacto</h3>
          <ul class="space-y-2 text-sm">
            <li>{empresa.razonSocial}</li>
            <li>
              <a href={`mailto:${empresa.correo}`} class="transition-colors hover:text-white"
                >{empresa.correo}</a>
            </li>
            <li>
              <a href={empresa.telefonoHref} class="transition-colors hover:text-white">{empresa.telefono}</a>
            </li>
            <li>{empresa.direccion}</li>
            <li>{empresa.horarioCorto}</li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/10">
        <p class="mx-auto max-w-5xl px-5 py-4 text-center text-xs">
          Versión {documento.version} | {empresa.razonSocial} | © {documento.anio} — Última actualización: {
            documento.actualizacion
          }
        </p>
      </div>
    </footer>

    <script>
      // Mantiene aria-expanded del menú "Legal" sincronizado con hover/foco
      document.querySelectorAll<HTMLElement>("[data-dropdown]").forEach((dd) => {
        const boton = dd.querySelector("button");
        if (!boton) return;
        const abrir = (abierto: boolean) => boton.setAttribute("aria-expanded", String(abierto));
        dd.addEventListener("mouseenter", () => abrir(true));
        dd.addEventListener("mouseleave", () => abrir(false));
        dd.addEventListener("focusin", () => abrir(true));
        dd.addEventListener("focusout", (e) => {
          if (!dd.contains(e.relatedTarget as Node)) abrir(false);
        });
      });
    </script>
  </body>
</html>
