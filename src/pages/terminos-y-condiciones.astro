  <script>
    // Resalta en el índice lateral la sección visible al hacer scroll
    const enlaces = new Map(
      [...document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]")].map((a) => [
        a.dataset.tocLink!,
        a,
      ]),
    );
    const activas = new Set<string>();
    const activar = () => {
      enlaces.forEach((a) => a.classList.remove("border-naranja", "text-carbon", "font-semibold"));
      const primera = [...document.querySelectorAll<HTMLElement>("[data-seccion]")].find((s) =>
        activas.has(s.id),
      );
      if (primera) enlaces.get(primera.id)?.classList.add("border-naranja", "text-carbon", "font-semibold");
    };
    const observer = new IntersectionObserver(
      (entries) => {
        for (const e of entries) e.isIntersecting ? activas.add(e.target.id) : activas.delete(e.target.id);
        activar();
      },
      { rootMargin: "-15% 0px -60% 0px" },
    );
    document.querySelectorAll("[data-seccion]").forEach((s) => observer.observe(s));
  </script>
